PORT=4000
JWT_SECRET=replace-with-strong-secret
DB_PROVIDER=json
SQLITE_DB_PATH=
ADMIN_BOOTSTRAP_SECRET=
# Seeded demo users are opt-in only. Existing seeded accounts can be enabled/disabled with:
# npm run job:seeded-demo-users -- --apply --allow
# npm run job:seeded-demo-users -- --apply --disable
# To remove old seeded demo accounts and their related demo data entirely:
# npm run job:seeded-demo-users -- --apply --purge
# Create the first real admin account with either:
# npm run job:create-admin -- --apply --name="Ops Admin" --email="ops@example.com" --mobile="9876543210" --password="StrongPass1" --address="Jaipur"
# or POST /api/auth/admin/bootstrap with x-admin-bootstrap-secret: $ADMIN_BOOTSTRAP_SECRET
ALLOW_SEEDED_DEMO_USERS=false
ALLOW_PASSWORD_AUTH_FALLBACK=false
# Payment provider: simulated | razorpay
PAYMENT_PROVIDER=simulated
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Smoke test: npm run smoke:razorpay -- --amount=1
# Resume verifier: npm run verify:razorpay-resume
# Point Razorpay webhooks to POST /api/payments/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_PARENT_FOLDER_ID=
GOOGLE_DRIVE_CATEGORY_FOLDER_MAP_JSON={"laptop":"folderId123","mobile":"folderId456"}
GOOGLE_DRIVE_MAKE_PUBLIC=true
BACK_IN_STOCK_EMAIL_MODE=simulated
PUBLIC_STORE_BASE_URL=http://localhost:5500
PUBLIC_API_BASE_URL=http://localhost:4000/api
STORE_BRAND_NAME=ElectroMart
STORE_SUPPORT_EMAIL=support@electromart.com
STORE_PRIMARY_COLOR=#0f766e
# Phone verification scheduler values act as backend defaults until admin settings override them.
PHONE_VERIFICATION_MODE=simulated
PHONE_VERIFICATION_AUTOMATION_ENABLED=false
PHONE_VERIFICATION_AUTOMATION_RUN_ON_START=false
PHONE_VERIFICATION_AUTOMATION_INTERVAL_MINUTES=720
PHONE_VERIFICATION_AUTOMATION_CHANNELS=sms,email
PHONE_VERIFICATION_REMINDER_BATCH_LIMIT=25
PHONE_VERIFICATION_REMINDER_COOLDOWN_MS=43200000
PHONE_VERIFICATION_REMINDER_MAX_ATTEMPTS=3
PHONE_VERIFICATION_REMINDER_RETRY_BACKOFF_MS=1800000
ORDER_RESERVATION_TTL_MINUTES=15
ORDER_RESERVATION_SWEEP_INTERVAL_MS=60000
ALERT_MIN_REQUEST_VOLUME_5M=20
ALERT_ERROR_RATE_PERCENT_5M=5
ALERT_AVG_LATENCY_MS_5M=1200
ALERT_MAX_LATENCY_MS_5M=5000
ALERT_ESCALATION_TARGETS=email:ops-oncall@electromart.in,slack:#incident-ops
# Optional override for runbook links included in alert payloads.
# ALERT_RUNBOOK_BASE_URL=https://github.com/chouhantrade1986-glitch/Electronic-Store/blob/main/PRODUCTION-INCIDENT-RUNBOOK.md

# Optional smoke/resume verifier overrides
SMOKE_TEST_USER=customer@electromart.com
SMOKE_TEST_PASSWORD=Customer@123
SMOKE_TEST_PRODUCT_ID=1
SMOKE_TEST_PRODUCT_QTY=1
SMOKE_TEST_PAYMENT_METHOD=upi
SMOKE_TEST_ADDRESS=Jaipur, Rajasthan

# SMTP mode (set BACK_IN_STOCK_EMAIL_MODE=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ElectroMart

# SendGrid mode (set BACK_IN_STOCK_EMAIL_MODE=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=ElectroMart
