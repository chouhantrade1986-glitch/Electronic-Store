{
  "name": "electromart-root",
  "private": true,
  "version": "1.0.0",
  "description": "Root tooling for ElectroMart smoke and browser QA flows.",
  "scripts": {
    "csv:preflight": "node tools/csv-preflight-check.js",
    "csv:convert:wix": "node tools/convert-wix-catalog-csv.js",
    "csv:convert:project": "node tools/convert-wix-catalog-csv.js",
    "smoke": "node qa-full-smoke.js --reports-dir=qa-reports",
    "smoke:ui": "node qa-ui-smoke.js --artifacts-dir=qa-reports/ui",
    "smoke:baseline:lock": "powershell -ExecutionPolicy Bypass -File .\\lock-visual-baseline.ps1",
    "smoke:baseline:verify": "powershell -ExecutionPolicy Bypass -File .\\verify-visual-baseline.ps1",
    "smoke:install-browsers": "npx playwright install chromium",
    "release:preflight": "powershell -ExecutionPolicy Bypass -File .\\release-preflight.ps1",
    "release:verify:postdeploy": "npm.cmd --prefix backend run job:release:verify --",
    "release:rollback:dry": "powershell -ExecutionPolicy Bypass -File .\\release-rollback-dry-run.ps1",
    "audit:evidence:weekly": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ci\\generate-weekly-audit-evidence.ps1",
    "cleanup:artifacts": "powershell -ExecutionPolicy Bypass -File .\\cleanup-generated-artifacts.ps1 -Apply",
    "cleanup:artifacts:dry": "powershell -ExecutionPolicy Bypass -File .\\cleanup-generated-artifacts.ps1",
    "branch:protect:main": "powershell -ExecutionPolicy Bypass -File .\\set-main-branch-protection.ps1",
    "branch:protect:check": "powershell -ExecutionPolicy Bypass -File .\\set-main-branch-protection.ps1 -CheckOnly",
    "issues:prod-hardening": "powershell -ExecutionPolicy Bypass -File .\\create-production-hardening-issues.ps1"
  },
  "devDependencies": {
    "playwright": "1.58.2"
  }
}
